# LLM settings
API_KEY=replace_with_your_model_api_key
MODEL_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL_NAME=deepseek-ai/DeepSeek-V4-Pro
LLM_ENABLE_SEARCH=false

# Xianyu login. Keep real cookies only in .env.
COOKIES_STR=your_cookies_here

# Runtime tuning
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300
COOKIE_REFRESH_ENABLED=true
COOKIE_REFRESH_INTERVAL=600
COOKIE_REFRESH_RETRY_INTERVAL=300
MANUAL_MODE_TIMEOUT=3600
MESSAGE_EXPIRE_TIME=300000
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=false

# High-risk automation defaults. Keep disabled unless explicitly accepted.
AUTO_REPLY_ENABLED=true
AUTO_DELIVERY_ENABLED=false
AUTO_CONFIRM_DELIVERY_ENABLED=false
AUTO_RELIST_ENABLED=false
PLAYWRIGHT_HEADLESS=true
