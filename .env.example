# LLM settings
API_KEY=replace_with_your_model_api_key
MODEL_BASE_URL=https://api-inference.modelscope.cn/v1
MODEL_NAME=ZhipuAI/GLM-5.2,Qwen/Qwen3.5-397B-A17B,deepseek-ai/DeepSeek-V4-Flash,MiniMax/MiniMax-M3,XiaomiMiMo/MiMo-V2-Flash
MODEL_REQUEST_TIMEOUT=12
REPLY_GENERATION_TIMEOUT=25
LLM_ENABLE_SEARCH=false

# Xianyu login. Keep real cookies only in .env.
COOKIES_STR=your_cookies_here

# Runtime tuning
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300
COOKIE_REFRESH_ENABLED=true
COOKIE_REFRESH_INTERVAL=600
COOKIE_REFRESH_RETRY_INTERVAL=300
MANUAL_MODE_TIMEOUT=3600
MESSAGE_EXPIRE_TIME=300000
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=false
ITEM_KNOWLEDGE_DIR=data/item_knowledge
ITEM_KNOWLEDGE_MAX_CHARS=6000
UNKNOWN_QUESTIONS_PATH=data/unknown_questions.jsonl

# High-risk automation defaults. Keep disabled unless explicitly accepted.
AUTO_REPLY_ENABLED=true
NO_BARGAIN_MODE=true
AUTO_DELIVERY_ENABLED=false
AUTO_CONFIRM_DELIVERY_ENABLED=false
AUTO_RELIST_ENABLED=false
AUTO_RELIST_ALLOW_PLAYWRIGHT=false
AUTO_RELIST_CONFIRM_PLAYWRIGHT=false
XIANYU_RELIST_API=
AUTO_RELIST_SCREENSHOT_DIR=data/relist-screenshots
AUTO_RELIST_PLAYWRIGHT_HEADLESS=true
AUTO_RELIST_MANAGEMENT_URL=
AUTO_REVIEW_ENABLED=false
AUTO_REVIEW_CONFIRM_PLAYWRIGHT=false
AUTO_REVIEW_ORDER_URL_TEMPLATE=
AUTO_REVIEW_SCREENSHOT_DIR=data/review-screenshots
AUTO_REVIEW_PLAYWRIGHT_HEADLESS=true
AUTO_PUBLISH_SCREENSHOT_DIR=data/publish-screenshots
AUTO_PUBLISH_PLAYWRIGHT_HEADLESS=true
AUTO_PUBLISH_URL=
PLAYWRIGHT_HEADLESS=true
WEB_HOST=127.0.0.1
WEB_PORT=8765
